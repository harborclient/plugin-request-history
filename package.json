{
  "name": "harborclient-plugin-recent-requests",
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "build": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --platform=neutral --jsx=automatic --jsx-import-source=@harborclient/sdk --external:react --external:react-dom",
    "verify": "node scripts/verify.mjs",
    "dev": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --platform=neutral --jsx=automatic --jsx-import-source=@harborclient/sdk --external:react --external:react-dom --watch",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "devDependencies": {
    "@harborclient/sdk": "^0.4.3",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  }
}
